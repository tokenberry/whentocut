// WhenToCut data model. Postgres on the DigitalOcean droplet.
// Schema is applied with `prisma db push` during deploy (see scripts/deploy.sh).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Auth.js (NextAuth) models ------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  plan          Plan      @default(FREE)
  createdAt     DateTime  @default(now())

  // Polar billing (set by the subscription webhook)
  polarCustomerId     String?
  polarSubscriptionId String?

  accounts          Account[]
  sessions          Session[]
  trackedGames      TrackedGame[]
  alerts            AlertSubscription[]
  partnerCredential PartnerCredential?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

enum Plan {
  FREE
  PRO
}

// ---- Domain models (per user) -------------------------------------------------

/// A Steam game a user tracks for discount advice.
model TrackedGame {
  id        String   @id @default(cuid())
  userId    String
  appid     Int
  name      String
  createdAt DateTime @default(now())

  // Alert de-duplication: only email when the recommendation meaningfully changes.
  lastAlertedAt      DateTime?
  lastAlertSignature String?

  user   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  alerts AlertSubscription[]

  @@unique([userId, appid])
  @@index([userId])
}

/// Periodic capture of public market state (global, shared across users). History
/// powers trends, cooldown tracking, and prior-discount counts.
model Snapshot {
  id                 String   @id @default(cuid())
  appid              Int
  capturedAt         DateTime @default(now())
  currentPriceCents  Int?
  basePriceCents     Int?
  currentDiscountPct Int      @default(0)
  currentPlayers     Int?
  rivalsOnSaleFrac   Float?
  archiveKey         String? // full snapshot JSON archived to DO Spaces

  @@index([appid, capturedAt])
}

/// A user's Steamworks partner Web API key — encrypted at rest, server-side only.
model PartnerCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  encryptedKey String // AES-GCM ciphertext (hex)
  iv           String // AES-GCM iv (hex)
  authTag      String // AES-GCM auth tag (hex)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Where to send alerts when a recommendation triggers.
model AlertSubscription {
  id          String       @id @default(cuid())
  userId      String
  appid       Int
  channel     AlertChannel
  target      String // email address or Discord webhook URL
  createdAt   DateTime     @default(now())
  lastFiredAt DateTime?

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackedGame TrackedGame @relation(fields: [userId, appid], references: [userId, appid], onDelete: Cascade)

  @@index([userId, appid])
}

enum AlertChannel {
  EMAIL
  DISCORD
}
