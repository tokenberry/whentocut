# Copy to .env on the droplet and fill in. NEVER commit the real .env.

# Port the app listens on. On a SHARED droplet use a free port (not the other app's).
PORT=3001

# Postgres — REQUIRED now (accounts, tracked games, alerts).
# Reuse the droplet's existing Postgres with a dedicated DB/user.
DATABASE_URL="postgresql://whentocut:CHANGEME@localhost:5432/whentocut?schema=public"

# --- Auth.js (NextAuth) ---
# openssl rand -base64 33
AUTH_SECRET=""
# Public URL of the site (used to build callback URLs)
AUTH_URL="https://whentocut.com"
AUTH_TRUST_HOST="true"
# Google OAuth (console.cloud.google.com -> OAuth client; callback:
#   https://whentocut.com/api/auth/callback/google )
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Magic-link email via Resend
AUTH_RESEND_KEY=""
AUTH_EMAIL_FROM="login@whentocut.com"

# 32-byte (hex) key for AES-GCM encryption of partner Web API keys at rest
ENCRYPTION_KEY=""

# Steamworks PARTNER Web API key (single-tenant: your own games). Server-side only —
# never expose to the browser. Needs the "Sales Data" permission, or use a financial key.
# A financial key (unrestricted sales/wishlist across all your apps) takes precedence.
STEAMWORKS_PARTNER_KEY=""
STEAMWORKS_FINANCIAL_KEY=""

# Shared secret guarding POST /api/cron/evaluate
CRON_SECRET=""

# Email alerts (Resend)
RESEND_API_KEY=""
ALERT_FROM_EMAIL="alerts@whentocut.app"

# DigitalOcean Spaces (S3-compatible) for snapshot archives / exports
DO_SPACES_KEY=""
DO_SPACES_SECRET=""
DO_SPACES_ENDPOINT="https://nyc3.digitaloceanspaces.com"
DO_SPACES_BUCKET="whentocut"
