# WhenToCut reverse-proxy — a DEDICATED, ADDITIVE server block.
# It only matches your WhenToCut subdomain, so it does not affect any existing site.
#
# Install:
#   sudo cp deploy/nginx/whentocut.conf.example /etc/nginx/sites-available/whentocut.conf
#   # edit server_name + the proxy_pass port to match PORT in your .env
#   sudo ln -s /etc/nginx/sites-available/whentocut.conf /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d whentocut.example.com   # adds HTTPS, edits THIS file only

server {
    listen 80;
    listen [::]:80;

    server_name whentocut.example.com;   # <-- your subdomain (needs a DNS A record -> droplet IP)

    location / {
        proxy_pass http://127.0.0.1:3001;   # <-- must match PORT in .env
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
